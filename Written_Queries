
SELECT COUNT(*) FROM cleaned_movies_metadata; 
 
SELECT MIN(release_date), MAX(release_date) FROM cleaned_movies_metadata; 

SELECT COUNT(*) FROM cleaned_movies_metadata WHERE release_date IS NULL; 
 

SELECT year(release_date) AS year, COUNT(*) AS movie_count 

FROM cleaned_movies_metadata 

GROUP BY year(release_date) 

ORDER BY year; 


SELECT year(release_date) AS year, AVG(vote_average) AS avg_rating 

FROM cleaned_movies_metadata 

GROUP BY year(release_date) 

ORDER BY year; 
 

SELECT year(release_date) AS year, SUM(revenue) AS total_revenue 

FROM cleaned_movies_metadata 

GROUP BY year(release_date) 

ORDER BY year; 


SELECT language, COUNT(*) AS movie_count 

FROM cleaned_movies_metadata 

GROUP BY language 

ORDER BY movie_count DESC; 


SELECT language, AVG(vote_average) AS avg_rating 

FROM cleaned_movies_metadata 

GROUP BY language 

ORDER BY avg_rating DESC; 

 year(release_date) AS year, 

  language, 

  COUNT(*) AS movie_count, 

  AVG(vote_average) AS avg_rating, 

  SUM(revenue) AS total_revenue 

FROM cleaned_movies_metadata 

WHERE release_date IS NOT NULL 

GROUP BY year(release_date), language 

ORDER BY year, movie_count DESC; 



 --Genre‑Based Analysis

SELECT movie_genre, AVG(tmdb_rating) AS avg_tmdb
FROM combined_movies
GROUP BY movie_genre
ORDER BY avg_tmdb DESC
LIMIT 10;

--Cross‑Platform Rating Comparison
SELECT           
  movie_title,
  tmdb_rating,
  movielens_rating,
  (tmdb_rating - movielens_rating) AS rating_gap
FROM combined_movies
ORDER BY rating_gap DESC
LIMIT 20;

--Rating Distribution
SELECT tmdb_rating, COUNT(*) AS count 
FROM combined_movies
GROUP BY tmdb_rating
ORDER BY tmdb_rating
LIMIT 15;

--Genre‑Specific Rating Gaps
SELECT
  movie_genre,
  AVG(tmdb_rating - movielens_rating) AS avg_gap
FROM combined_movies
GROUP BY movie_genre
ORDER BY avg_gap DESC
LIMIT 10;




